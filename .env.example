# Copia este archivo a .env (gitignored) para configuración local.
# Todas las variables son opcionales; sin .env se usan los defaults.

# dev | paper | live
QUANTBOT_ENVIRONMENT=dev

# Ruta de la base de datos SQLite de trazabilidad
QUANTBOT_DB_PATH=data/quantbot.sqlite

# Directorio de logs persistentes (canal de respaldo, spec seccion 4.5)
QUANTBOT_LOG_DIR=logs

# TRACE | DEBUG | INFO | SUCCESS | WARNING | ERROR | CRITICAL
QUANTBOT_LOG_LEVEL=INFO

# User-Agent para la SEC/EDGAR (motor Insider). La SEC EXIGE un contacto
# real con formato "nombre contacto email"; devuelve HTTP 403 sin el.
QUANTBOT_SEC_USER_AGENT=botcompartido quantbot tu-email@ejemplo.com
